import { GoogleGenAI } from "@google/genai";
import { NextResponse } from "next/server";

// We extract categories and subcategories to provide them to the AI context.
// In a production app, this might be cached or dynamically fetched if too large.
import { categories, partsSubcategories as subcategories, partItems, brands, models } from "@/lib/vehicle-data";

// Initialize Gemini Client
const ai = new GoogleGenAI({ apiKey: process.env.GEMINI_API_KEY });

// System instruction for the Gemini model to parse user queries into our structured schema.
const systemInstruction = `
Te vagy a BONTÓÁRUHÁZ intelligens okoskereső asszisztense.
Feladatod: A felhasználó (vásárló) által beírt szabad szöveget, alkatrésznevet, autótípust vagy pontos cikkszámot (SKU/OEM) elemezd, és alakítsd át strukturált JSON keresési paraméterekké a mi adatbázisunkhoz.

A Te JSON válaszod fogja vezérelni a keresőoldal URL paramétereit.
SZIGORÚAN CSAK ÉRVÉNYES JSON-T VÁLASZOLHATSSZ. NE LEGYEN MÁS SZÖVEG.

### Adatbázisunk (Referencia az egyezéshez):
A rendelkezésre álló Márkák (slug-ok): ${brands.map(b => b.slug).join(', ')}
A rendelkezésre álló Kategóriák (slug-ok): ${categories.map(c => c.slug).join(', ')}
A rendelkezésre álló Alkategóriák (slug-ok, részlet): ${subcategories.slice(0, 100).map(s => s.slug).join(', ')}... 
A rendelkezésre álló Egyedi alkatrészek (nincs korlát) (slug-ok): ${partItems.map(p => p.slug).join(', ')}

### JSON SÉMA (Ezt KELL visszaadnod):
{
  "brand": "márka slug vagy null",
  "model": "modell pontos megnevezése vagy null (fontos! ne találj ki id-t, add vissza a modellt ahogy leírta)",
  "category": "főkategória slug vagy null",
  "subcategory": "alkategória slug vagy null",
  "item": "egyedi alkatrész (part item) slug vagy null",
  "sku": "kiszűrt gyári cikkszám vagy oem kód (tisztítva) vagy null",
  "query": "A megmaradt szabad szavas keresőkifejezés (ami nem egyértelmű kategória vagy autó), ha mindent tudtál kategorizálni, akkor üres string vagy null",
  "explanation": "Nagyon rövid magyar magyarázat magadnak (1 mondat), hogy mi alapján döntöttél."
}

### Szabályok:
1. Ha a felhasználó egy egyértelmű cikkszámot ("5G1 941 005") ír, tedd az 'sku' mezőbe. Szóközzel vagy anélkül is lehet cikkszám.
2. Ha autómárkát ismered fel, a fenti listából választ ki a PONTOS 'slug' azonosítót.
3. A modell nevét ("A3", "Golf", "Focus") oszd be a "model" mezőbe, ezt egy későbbi algoritmus illeszti a mi slug-jainkhoz.
4. Ha konrkét egyedi alkatrészt keres (pl. "bal első lámpa"), keresd meg a legjobb egyezést az Egyedi alkatrészek listából, és azt tedd az 'item' alá. Ha főkategória (pl. "engine"), akkor a 'category'-ba. Ha alkategória, a 'subcategory'-ba. Ha teheted, mind a 3 szintet (category, subcategory, item) is töltsd ki, ha logikusan következnek egymásból.
5. Soha ne találj ki új slug-okat. Ha nem vagy biztos benne, hagyd null-on a megfelelő mezőt.
`;

export async function POST(req: Request) {
    try {
        const { query } = await req.json();

        if (!query || typeof query !== "string") {
            return NextResponse.json({ error: "Hibás keresési kérés." }, { status: 400 });
        }

        // Call Gemini API
        const response = await ai.models.generateContent({
            model: "gemini-2.5-flash",
            contents: query,
            config: {
                systemInstruction: systemInstruction,
                responseMimeType: "application/json",
                temperature: 0.1, // Keep it deterministic for structured extraction
            }
        });

        const rawText = response.text;
        if (!rawText) {
            throw new Error("Empty response from AI");
        }

        // Parse JSON (Gemini will return JSON as requested by responseMimeType)
        const parsedResult = JSON.parse(rawText);

        // --- BACKEND SANITIZATION / EXACT MATCHING ---
        // Match brand strictly
        let finalBrandSlug = null;
        if (parsedResult.brand) {
            const b = brands.find(x => x.slug.toLowerCase() === parsedResult.brand.toLowerCase() || x.name.toLowerCase() === parsedResult.brand.toLowerCase());
            if (b) finalBrandSlug = b.slug;
        }

        // Match model via basic fuzzy matching
        let finalModelSlug = null;
        if (parsedResult.model && finalBrandSlug) {
            const brandId = brands.find(b => b.slug === finalBrandSlug)?.id;
            const availableModels = models.filter(m => m.brandId === brandId);
            const m = availableModels.find(x => x.slug.toLowerCase() === String(parsedResult.model).toLowerCase() || x.name.toLowerCase() === String(parsedResult.model).toLowerCase() || x.slug.includes(String(parsedResult.model).toLowerCase().replace(/\s+/g, '-')));
            if (m) finalModelSlug = m.slug;
            else {
                // very basic fallback: strip spaces
                const stripped = String(parsedResult.model).toLowerCase().replace(/\s+/g, '');
                const m2 = availableModels.find(x => x.slug.replace(/\-/g, '').includes(stripped));
                if (m2) finalModelSlug = m2.slug;
            }
        }

        let finalCategorySlug = null;
        if (parsedResult.category) {
            const c = categories.find(x => x.slug.toLowerCase() === parsedResult.category.toLowerCase());
            if (c) finalCategorySlug = c.slug;
        }

        let finalSubcategorySlug = null;
        if (parsedResult.subcategory) {
            const s = subcategories.find(x => x.slug.toLowerCase() === parsedResult.subcategory.toLowerCase());
            if (s) finalSubcategorySlug = s.slug;
        }

        let finalItemSlug = null;
        if (parsedResult.item) {
            const i = partItems.find(x => x.slug.toLowerCase() === parsedResult.item.toLowerCase());
            if (i) finalItemSlug = i.slug;
        }

        const finalResult = {
            ...parsedResult,
            brand: finalBrandSlug,
            model: finalModelSlug,
            category: finalCategorySlug,
            subcategory: finalSubcategorySlug,
            item: finalItemSlug
        };

        return NextResponse.json(finalResult);
    } catch (error) {
        console.error("AI Search Error:", error);
        return NextResponse.json({ error: "Hiba az AI keresés során." }, { status: 500 });
    }
}
