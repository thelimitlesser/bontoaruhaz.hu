generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(uuid())
  email           String          @unique
  fullName        String?
  role            String          @default("CUSTOMER")
  taxId           String?
  companyName     String?
  isVerified      String          @default("FALSE")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  phoneNumber     String?
  shippingAddress String?
  orders          Order[]
  partnerProfile  PartnerProfile?
  vehicles        UserVehicle[]
}

model PartnerProfile {
  id           String  @id @default(uuid())
  userId       String  @unique
  businessName String
  rating       Float   @default(0)
  returnPolicy String?
  parts        Part[]
  user         User    @relation(fields: [userId], references: [id])
}

model UserVehicle {
  id         String  @id @default(uuid())
  userId     String
  vin        String?
  make       String
  model      String
  year       Int
  engineCode String?
  nickname   String?
  user       User    @relation(fields: [userId], references: [id])
}

model Part {
  id              String              @id @default(uuid())
  sku             String
  name            String
  description     String?
  categoryId      String?
  subcategoryId   String?
  priceNet        Int
  priceGross      Int
  currency        String              @default("HUF")
  vatRate         Int                 @default(27)
  oemNumbers      String
  condition       String              @default("USED")
  tecdocKTypes    String
  partnerId       String
  brandId         String?
  modelId         String?
  partItemId      String?
  yearFrom        Int?
  yearTo          Int?
  images          String
  stock           Int                 @default(1)
  createdAt       DateTime            @default(now())
  isUniversal     Boolean             @default(false)
  productCode     String?
  height          Float?
  length          Float?
  shippingPrice   Int?
  weight          Float?
  width           Float?
  engineCode      String?
  orderItems      OrderItem[]
  VehicleBrand    VehicleBrand?       @relation(fields: [brandId], references: [id])
  PartCategory    PartCategory?       @relation(fields: [categoryId], references: [id])
  VehicleModel    VehicleModel?       @relation(fields: [modelId], references: [id])
  PartItem        PartItem?           @relation(fields: [partItemId], references: [id])
  partner         PartnerProfile      @relation(fields: [partnerId], references: [id])
  PartSubcategory PartSubcategory?    @relation(fields: [subcategoryId], references: [id])
  compatibilities PartCompatibility[]
  events          PartEvent[]
  reservations    Reservation[]

  @@index([sku])
  @@index([productCode])
  @@index([brandId])
  @@index([modelId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([partItemId])
  @@index([createdAt])
}

model Order {
  id                    String      @id @default(uuid())
  userId                String?
  status                String      @default("PENDING")
  totalAmount           Int
  shippingAddress       String
  billingAddress        String
  createdAt             DateTime    @default(now())
  paymentMethod         String      @default("CARD")
  paymentStatus         String      @default("PENDING")
  shippingMethod        String      @default("DELIVERY")
  stripePaymentIntentId String?     // ID for Stripe Authorization/PaymentIntent
  trackingNumber        String?     // Pannon XP tracking number
  invoiceId             String?     // Számlázz.hu invoice ID/Number
  user                  User?       @relation(fields: [userId], references: [id])
  items                 OrderItem[]
}

model OrderItem {
  id          String @id @default(uuid())
  orderId     String
  partId      String
  quantity    Int
  priceAtTime Int
  order       Order  @relation(fields: [orderId], references: [id])
  part        Part   @relation(fields: [partId], references: [id])
}

model DonorVehicle {
  id         String   @id @default(uuid())
  vin        String   @unique
  make       String
  model      String
  year       Int
  engineCode String?
  mileage    Int?
  colorCode  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model StorageLocation {
  id          String  @id @default(uuid())
  name        String
  description String?
}

model SearchLog {
  id             String   @id @default(uuid())
  query          String   @unique
  count          Int      @default(1)
  lastSearchedAt DateTime @default(now())
}

model PartCompatibility {
  id           String       @id @default(uuid())
  partId       String
  brandId      String
  modelId      String
  yearFrom     Int?
  yearTo       Int?
  VehicleModel VehicleModel @relation(fields: [modelId], references: [id])
  part         Part         @relation(fields: [partId], references: [id], onDelete: Cascade)
}

model PartCategory {
  id              String            @id
  name            String
  slug            String            @unique
  iconName        String?
  keywords        String[]
  Part            Part[]
  PartSubcategory PartSubcategory[]
}

model PartItem {
  id              String          @id
  subcategoryId   String
  name            String
  slug            String
  keywords        String[]
  Part            Part[]
  PartSubcategory PartSubcategory @relation(fields: [subcategoryId], references: [id])
}

model PartSubcategory {
  id           String       @id
  categoryId   String
  name         String
  slug         String
  keywords     String[]
  Part         Part[]
  PartItem     PartItem[]
  PartCategory PartCategory @relation(fields: [categoryId], references: [id])
}

model VehicleBrand {
  id           String         @id
  name         String
  slug         String         @unique
  logo         String
  hidden       Boolean        @default(false)
  scale        String?
  Part         Part[]
  VehicleModel VehicleModel[]
}

model VehicleModel {
  id                String              @id
  brandId           String
  name              String
  slug              String
  series            String?
  keywords          String[]
  years             String?
  Part              Part[]
  PartCompatibility PartCompatibility[]
  VehicleBrand      VehicleBrand        @relation(fields: [brandId], references: [id])
}
model Reservation {
  id        String   @id @default(uuid())
  partId    String
  sessionId String
  quantity  Int      @default(1)
  expiresAt DateTime
  createdAt DateTime @default(now())
  part      Part     @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@unique([partId, sessionId])
  @@index([partId])
  @@index([sessionId])
  @@index([expiresAt])
}
