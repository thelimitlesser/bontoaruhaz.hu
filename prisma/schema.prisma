generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(uuid())
  email           String          @unique
  fullName        String?
  role            String          @default("CUSTOMER")
  taxId           String?
  companyName     String?
  isVerified      String          @default("FALSE")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  phoneNumber     String?
  shippingAddress String?
  orders          Order[]
  partnerProfile  PartnerProfile?
  vehicles        UserVehicle[]
}

model PartnerProfile {
  id           String  @id @default(uuid())
  userId       String  @unique
  businessName String
  rating       Float   @default(0)
  returnPolicy String?
  parts        Part[]
  user         User    @relation(fields: [userId], references: [id])
}

model UserVehicle {
  id         String  @id @default(uuid())
  userId     String
  vin        String?
  make       String
  model      String
  year       Int
  engineCode String?
  nickname   String?
  user       User    @relation(fields: [userId], references: [id])
}

model Part {
  id              String              @id @default(uuid())
  sku             String
  name            String
  description     String?
  categoryId      String?
  subcategoryId   String?
  priceNet        Int
  priceGross      Int
  currency        String              @default("HUF")
  vatRate         Int                 @default(27)
  oemNumbers      String
  condition       String              @default("USED")
  tecdocKTypes    String
  partnerId       String
  brandId         String?
  modelId         String?
  partItemId      String?
  yearFrom        Int?
  yearTo          Int?
  images          String
  stock           Int                 @default(1)
  createdAt       DateTime            @default(now())
  isUniversal     Boolean             @default(false)
  productCode     String?
  orderItems      OrderItem[]
  partner         PartnerProfile      @relation(fields: [partnerId], references: [id])
  compatibilities PartCompatibility[]
}

model Order {
  id              String      @id @default(uuid())
  userId          String?
  status          String      @default("PENDING")
  totalAmount     Int
  shippingAddress String
  billingAddress  String
  createdAt       DateTime    @default(now())
  paymentMethod   String      @default("CARD")
  paymentStatus   String      @default("PENDING")
  shippingMethod  String      @default("DELIVERY")
  user            User?       @relation(fields: [userId], references: [id])
  items           OrderItem[]
}

model OrderItem {
  id          String @id @default(uuid())
  orderId     String
  partId      String
  quantity    Int
  priceAtTime Int
  order       Order  @relation(fields: [orderId], references: [id])
  part        Part   @relation(fields: [partId], references: [id])
}

model DonorVehicle {
  id         String   @id @default(uuid())
  vin        String   @unique
  make       String
  model      String
  year       Int
  engineCode String?
  mileage    Int?
  colorCode  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model StorageLocation {
  id          String  @id @default(uuid())
  name        String
  description String?
}

model SearchLog {
  id             String   @id @default(uuid())
  query          String   @unique
  count          Int      @default(1)
  lastSearchedAt DateTime @default(now())
}

model PartCompatibility {
  id       String @id @default(uuid())
  partId   String
  brandId  String
  modelId  String
  yearFrom Int?
  yearTo   Int?
  part     Part   @relation(fields: [partId], references: [id], onDelete: Cascade)
}
